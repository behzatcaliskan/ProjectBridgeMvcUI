@using Microsoft.AspNetCore.Http
@model IEnumerable<projectbridgemvc.Models.Product>

@{
    ViewData["Title"] = "Products";
    var role = Context.Session.GetString("Role");
}

<h2 class="mt-4">Takı Ürünleri</h2>

@if (role == "Admin")
{
    <a asp-action="Create" class="btn btn-success mb-3">Yeni Ürün Ekle</a>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ürün Adı</th>
            <th>Materyal</th>
            <th>Renk</th>
            <th>Fiyat</th>
            <th>Stok</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.ProductId</td>
                    <td>@item.ProductName</td>
                    <td>@item.Material</td>
                    <td>@item.Color</td>
                    <td>@item.Price ₺</td>
                    <td>@item.Stock</td>
                    <td>
                        @if (role == "Admin")
                        {
                            <a asp-action="Edit" asp-route-id="@item.ProductId" class="btn btn-primary btn-sm">Güncelle</a>
                            <a asp-action="Delete" asp-route-id="@item.ProductId" class="btn btn-danger btn-sm">Sil</a>
                        }
                        else
                        {
                            <span class="text-muted">Sadece görüntüleme</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="7" class="text-center">Kayıt bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>