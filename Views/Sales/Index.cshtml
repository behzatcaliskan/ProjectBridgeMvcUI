@using Microsoft.AspNetCore.Http
@model IEnumerable<projectbridgemvc.Models.Sale>

@{
    ViewData["Title"] = "Sales";
    var role = Context.Session.GetString("Role");
}

<h2 class="mt-4">Satışlar</h2>

@if (role == "Admin")
{
    <a asp-action="Create" class="btn btn-success mb-3">Yeni Satış Ekle</a>
}

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ürün</th>
            <th>Adet</th>
            <th>Toplam Tutar</th>
            <th>Satış Tarihi</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.SaleId</td>
                    <td>@item.Product?.ProductName</td>
                    <td>@item.Quantity</td>
                    <td>@item.TotalPrice ₺</td>
                    <td>@item.SaleDate.ToString("dd.MM.yyyy HH:mm")</td>
                    <td>
                        @if (role == "Admin")
                        {
                            <a asp-action="Edit" asp-route-id="@item.SaleId" class="btn btn-primary btn-sm">Güncelle</a>
                            <a asp-action="Delete" asp-route-id="@item.SaleId" class="btn btn-danger btn-sm">Sil</a>
                        }
                        else
                        {
                            <span class="text-muted">Sadece görüntüleme</span>
                        }
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="6" class="text-center">Kayıt bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>