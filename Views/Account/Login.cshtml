@model projectbridgemvc.Models.AppUser

@{
    Layout = null;
}

<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <title>JewelBridge Login</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>

<body class="bg-light">

    <div class="container">
        <div class="row justify-content-center align-items-center" style="height:100vh;">
            <div class="col-md-4">

                <div class="card shadow">
                    <div class="card-header bg-dark text-white text-center">
                        <h3>JewelBridge</h3>
                        <p class="mb-0">Takı Mağazası Yönetim Sistemi</p>
                    </div>

                    <div class="card-body">

                        @if (ViewBag.Error != null)
                        {
                            <div class="alert alert-danger">
                                @ViewBag.Error
                            </div>
                        }

                        <form asp-action="Login" method="post">

                            <div class="mb-3">
                                <label class="form-label">Kullanıcı Adı</label>
                                <input asp-for="UserName" class="form-control" placeholder="admin veya user" />
                            </div>

                            <div class="mb-3">
                                <label class="form-label">Şifre</label>
                                <input asp-for="Password" type="password" class="form-control" placeholder="1234" />
                            </div>

                            <button type="submit" class="btn btn-dark w-100">
                                Giriş Yap
                            </button>

                        </form>

                    </div>

                    <div class="card-footer text-center">
                        <small>Admin: admin / 1234</small><br />
                        <small>User: user / 1234</small>
                    </div>
                </div>

            </div>
        </div>
    </div>

</body>
</html>