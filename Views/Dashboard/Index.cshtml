@using projectbridgemvc.Models

@{
    ViewData["Title"] = "Dashboard";
    var lastSales = ViewBag.LastSales as List<Sale>;
}

<div class="mb-4">
    <h2>JewelBridge Dashboard</h2>
    <p class="text-muted">Takı mağazası satış ve stok yönetim paneli</p>
</div>

<div class="row mb-4">

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Toplam Ürün</h6>
                <h2>@ViewBag.TotalProductCount</h2>
                <span class="badge bg-primary">Ürün Yönetimi</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Toplam Satış</h6>
                <h2>@ViewBag.TotalSaleCount</h2>
                <span class="badge bg-success">Satış Takibi</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Toplam Gelir</h6>
                <h2>@ViewBag.TotalRevenue ₺</h2>
                <span class="badge bg-warning text-dark">Gelir Raporu</span>
            </div>
        </div>
    </div>

    <div class="col-md-3">
        <div class="card border-0 shadow-sm">
            <div class="card-body">
                <h6 class="text-muted">Az Stoklu Ürün</h6>
                <h2>@ViewBag.LowStockCount</h2>
                <span class="badge bg-danger">Stok Uyarısı</span>
            </div>
        </div>
    </div>

</div>

<div class="row">

    <div class="col-md-8">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <strong>Son Satışlar</strong>
            </div>

            <div class="card-body">
                <table class="table table-striped">
                    <thead>
                        <tr>
                            <th>Ürün</th>
                            <th>Adet</th>
                            <th>Tutar</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>

                    <tbody>
                        @if (lastSales != null && lastSales.Any())
                        {
                            foreach (var item in lastSales)
                            {
                                <tr>
                                    <td>@item.Product?.ProductName</td>
                                    <td>@item.Quantity</td>
                                    <td>@item.TotalPrice ₺</td>
                                    <td>@item.SaleDate.ToString("dd.MM.yyyy")</td>
                                </tr>
                            }
                        }
                        else
                        {
                            <tr>
                                <td colspan="4" class="text-center">Henüz satış kaydı yok.</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <strong>Hızlı İşlemler</strong>
            </div>

            <div class="card-body d-grid gap-2">
                <a asp-controller="Products" asp-action="Index" class="btn btn-dark">Ürünleri Gör</a>
                <a asp-controller="Sales" asp-action="Index" class="btn btn-outline-dark">Satışları Gör</a>
                <a asp-controller="Reports" asp-action="Index" class="btn btn-outline-warning">Raporlara Git</a>
            </div>
        </div>
    </div>

</div>