@model IEnumerable<projectbridgemvc.Models.Customer>

@{
    ViewData["Title"] = "Customers";
}

<h2 class="mt-4">Müşteriler</h2>

<a asp-action="Create" class="btn btn-success mb-3">Yeni Müşteri Ekle</a>

<table class="table table-bordered table-striped">
    <thead>
        <tr>
            <th>ID</th>
            <th>Ad Soyad</th>
            <th>Telefon</th>
            <th>Email</th>
            <th>İşlemler</th>
        </tr>
    </thead>

    <tbody>
        @if (Model != null && Model.Any())
        {
            foreach (var item in Model)
            {
                <tr>
                    <td>@item.CustomerId</td>
                    <td>@item.FullName</td>
                    <td>@item.Phone</td>
                    <td>@item.Email</td>
                    <td>
                        <a asp-action="Edit" asp-route-id="@item.CustomerId" class="btn btn-primary btn-sm">Güncelle</a>
                        <a asp-action="Delete" asp-route-id="@item.CustomerId" class="btn btn-danger btn-sm">Sil</a>
                    </td>
                </tr>
            }
        }
        else
        {
            <tr>
                <td colspan="5" class="text-center">Kayıt bulunamadı.</td>
            </tr>
        }
    </tbody>
</table>